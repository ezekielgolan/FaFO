#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
ORGANIZER="$SCRIPT_DIR/files and folders organizer.py"
ENV_FILE="$SCRIPT_DIR/files and folders organizer - .env"
VENV_PYTHON="$SCRIPT_DIR/.venv/bin/python3"

if [[ -f "$ENV_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$ENV_FILE"
fi

if [[ -x "$VENV_PYTHON" ]]; then
  PYTHON_BIN="$VENV_PYTHON"
else
  PYTHON_BIN="python3"
fi

TARGET_DIR="$PWD"
if [[ $# -gt 0 && -d "$1" ]]; then
  TARGET_DIR="$1"
  shift
fi

cd "$TARGET_DIR"
exec "$PYTHON_BIN" "$ORGANIZER" "$@"
